QWEN_MODEL_CONFIG_PATH=./config/models/qwen2.5.json
QWEN_DEFAULT_MODEL_ID=qwen2.5-0.5b
QWEN25_05B_MODEL_PATH=Qwen/Qwen2.5-0.5B-Instruct
QWEN25_3B_MODEL_PATH=Qwen/Qwen2.5-3B-Instruct

# v1.0 default: use CPU for stability on macOS.
# MPS remains experimental because PyTorch/Transformers may hit MPS NDArray limits.
# For Apple GPU exploration, prefer the MLX route documented in docs/mlx.md.

# Legacy single-model override. If set, it overrides the default model path.
QWEN_MODEL_PATH=
QWEN_DEVICE=cpu
QWEN_DEVICE_MAP=auto
QWEN_TORCH_DTYPE=auto
QWEN_ATTENTION_IMPL=
QWEN_TRUST_REMOTE_CODE=0
QWEN_MAX_NEW_TOKENS=256
QWEN_TEMPERATURE=0.7
QWEN_TOP_P=0.9

AGENT_DB_PATH=./agent_memory.sqlite3
AGENT_HISTORY_TURNS=6
AGENT_MAX_REPLY_CHARS=900
AGENT_SYSTEM_PROMPT="你是一个本地部署的 Qwen 助手，请优先用中文回答并保持简洁。"

# Optional MPS experiment on Apple Silicon:
# QWEN_DEVICE=mps
# QWEN_ATTENTION_IMPL=sdpa
# QWEN_TORCH_DTYPE=float16
# PYTORCH_ENABLE_MPS_FALLBACK=1

# Optional MLX smoke test variables for experiments/mlx_qwen_smoke.py:
# MLX_QWEN_MODEL_ID=qwen2.5-0.5b
# MLX_QWEN_MODEL_PATH=mlx-community/Qwen2.5-0.5B-Instruct-4bit
# MLX_QWEN_MAX_TOKENS=128
# MLX_QWEN_TEMPERATURE=0.7
# MLX_QWEN_EOS_TOKEN=<|im_end|>

# 公众号配置；明文模式只需要 TOKEN。
WECHAT_OFFICIAL_TOKEN=replace_with_your_token
WECHAT_OFFICIAL_APP_ID=
WECHAT_OFFICIAL_AES_KEY=

# 企业微信回调配置；企业微信回调需要这三项。
WECOM_TOKEN=
WECOM_CORP_ID=
WECOM_AES_KEY=
